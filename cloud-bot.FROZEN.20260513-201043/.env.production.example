# Runtime
NODE_ENV=production
PORT=3001

# WhatsApp Cloud API
WABA_API_VERSION=v23.0
WABA_TOKEN=replace-with-meta-access-token
WABA_PHONE_NUMBER_ID=replace-with-phone-number-id
WABA_BUSINESS_ACCOUNT_ID=replace-with-business-account-id
WABA_VERIFY_TOKEN=replace-with-webhook-verify-token
VERIFY_TOKEN=replace-with-webhook-verify-token
WABA_TEST_MODE=0
WABA_REENGAGE_TEMPLATE=
WABA_LANGUAGE_CODE=en_US

# Debug
DEBUG_HTTP=0
DEBUG_WEBHOOK=0
DEBUG_SEND=0
SESS_TTL_SEC=172800
IDEM_TTL_SEC=86400

# Optional local AI add-on
AI_ENABLED=0
AI_BASE_URL=http://host.docker.internal:8080
AI_TIMEOUT_MS=12000
AI_TEMPERATURE=0.2

# Backend website on the other VPS
LARAVEL_API_URL=https://safecareorganisation.org/api
BACKEND_BASE_URL=https://safecareorganisation.org/api
BOT_FAST_BASE=https://safecareorganisation.org/api
BOT_URL=https://safecareorganisation.org
BOT_FETCH_BASE=https://safecareorganisation.org
MEDIA_BASE_URL=https://safecareorganisation.org
BOT_API_KEY=replace-with-backend-bot-api-key

# Branding / contact
BRAND_NAME=SafeCare Organisation
AGENT_NAME=Marilyn
MARILYN_IMAGE_URL=https://safecareorganisation.org/Marilyn.png
BANNER_IMAGE_URL=
ADMIN_PHONE=replace-with-admin-whatsapp-number
WHATSAPP_OPS_LIST=
WHATSAPP_OPS_GROUP_ID=

# Optional sticker/media IDs
SEASON_MODE=
MARILYN_STICKER_ID=
CELEBRATE_STICKER_URL=
THINKING_STICKER_URL=
CHRISTMAS_STICKER_ID=
HELP0_STICKER_ID=

# Optional external Redis if you later wire it in
REDIS_URL=redis://host.docker.internal:6379/1
SESSION_TTL_SEC=10800
MESSAGE_DEDUPE_TTL_SEC=86400
